# =============================================================================
# Buro environment variables
# Copy to .env and adjust for local development.
# buro.ss is planned production only — not registered or active yet.
# =============================================================================

# --- Local development (default) ---
DJANGO_SECRET_KEY=change-me-in-local-dev
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Optional: use docker-compose Postgres (falls back to SQLite if unset)
DATABASE_URL=postgresql://buro:buro@localhost:5432/buro

# Optional: use docker-compose Redis (falls back to in-memory channel layer if unset)
REDIS_URL=redis://localhost:6379/0

# --- Room cost controls (see docs/COST_CONTROLS.md) ---
ROOM_MAX_PARTICIPANTS=30
ROOM_MAX_DURATION_MINUTES=60
ROOM_MAX_PER_USER_PER_DAY=5
ROOM_AUTO_END_EMPTY_AFTER_MINUTES=5
ROOM_CREATION_ENABLED=True

# Internal scheduler token for POST /api/internal/cleanup-rooms/ (staging cron).
# Generate a strong random value; required on deployed backends using HTTP cleanup.
INTERNAL_CLEANUP_TOKEN=

# --- Frontend (Vite) ---
# Only these are read by the frontend code today.
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000
# NOTE: VITE_APP_DOMAIN, VITE_AUDIO_PROVIDER, and VITE_AGORA_APP_ID are NOT used by
# the frontend code. Audio provider + Agora app id come from the backend audio-token
# response. Leave them unset unless code starts consuming them.

# --- Staging (temporary Vercel / Koyeb / Render URLs — placeholders only) ---
# Backend (set on the Render/Koyeb service + the scheduled cleanup job):
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=<generate-strong-random-secret>
# DJANGO_ALLOWED_HOSTS=<your-backend-host>
# DJANGO_CORS_ALLOWED_ORIGINS=https://<your-frontend-host>
# DJANGO_CSRF_TRUSTED_ORIGINS=https://<your-backend-host>,https://<your-frontend-host>
# FRONTEND_URL=https://<your-frontend-host>
# DATABASE_URL=<postgres-connection-url>
# REDIS_URL=<redis-connection-url>
# ROOM_MAX_PARTICIPANTS=10
# ROOM_MAX_DURATION_MINUTES=30
# ROOM_MAX_PER_USER_PER_DAY=5
# ROOM_AUTO_END_EMPTY_AFTER_MINUTES=5
# ROOM_CREATION_ENABLED=True
# AUDIO_PROVIDER=mock
# AGORA_APP_ID=<agora-app-id-if-using-agora>
# AGORA_APP_CERTIFICATE=<agora-cert-if-using-agora>
# AGORA_TOKEN_EXPIRES_IN=3600
# INTERNAL_CLEANUP_TOKEN=<strong-random-token-for-cron-cleanup>
# Frontend (set on the static host):
# VITE_API_BASE_URL=https://<your-backend-host>/api
# VITE_WS_BASE_URL=wss://<your-backend-host>

# --- Production (future — connect only after staging is stable) ---
# buro.ss is not registered yet. Do not use until DNS is configured.
# DJANGO_ALLOWED_HOSTS=api.buro.ss,buro.ss,app.buro.ss
# DJANGO_CORS_ALLOWED_ORIGINS=https://buro.ss,https://app.buro.ss
# FRONTEND_URL=https://buro.ss
# VITE_API_BASE_URL=https://api.buro.ss/api
# VITE_WS_BASE_URL=wss://api.buro.ss
# VITE_APP_DOMAIN=buro.ss

# --- Third-party (future phases) ---
# RESEND_API_KEY=
# CLOUDINARY_URL=
# AUDIO_PROVIDER=mock
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=
# AGORA_TOKEN_EXPIRES_IN=3600
# AUDIO_PROVIDER_APP_ID=
# AUDIO_PROVIDER_APP_SECRET=
# AUDIO_PROVIDER_API_KEY=
# AUDIO_PROVIDER_API_SECRET=
